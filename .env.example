# SQLite cho dev local
DATABASE_URL="file:./dev.db"

# Khi deploy Vercel, đổi sang Postgres (Neon, Supabase, Vercel Postgres):
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Secret cho JWT session (tạo chuỗi ngẫu nhiên dài)
AUTH_SECRET="change-me-super-secret-min-32-chars-please"

# ============================================================
# VNPT SmartCA TH — Ký số điện tử (Bắt buộc nếu dùng SmartCA)
# Đây là credentials VNPT cấp cho TỔ CHỨC/NHÀ PHÁT TRIỂN
# (khác với CCCD/mật khẩu của từng bác sĩ)
# Liên hệ VNPT hoặc đối tác VNPT để lấy thông tin này.
# ============================================================
VNPT_SCA_URL="https://rmgateway.vnptit.vn/sca/sp769"
# UAT (test):  https://rmgateway.vnptit.vn/sca/sp769
# Production:  https://gwsca.vnpt.vn/sca/sp769
VNPT_SCA_SP_ID=""
VNPT_SCA_SP_PASSWORD=""

# (Tuỳ chọn) Vercel Blob — lưu file cận lâm sàng (PDF, hình ảnh)
# Tạo tại: vercel.com → Storage → Blob → tạo store → copy token
BLOB_READ_WRITE_TOKEN=""

# (Tuỳ chọn) SMTP để gửi email thông báo khoa
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="healthcheck@lienchieu.vn"
